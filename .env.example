# ── Analytics ─────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Email (nodemailer → Gmail SMTP) ──────────────────
# Used by /api/feedback — delivers feedback widget submissions to FEEDBACK_TO.
# Plan emails go through Resend. This is only for internal feedback routing.
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx   # App password — gmail.com → Security → App passwords
FEEDBACK_TO=you@gmail.com

# ── Resend (email list + plan delivery) ──────────────
# Contacts API uses segments: [{ id }] — not audienceId (deprecated).
# Each project gets its own Segment in the shared Resend team (free, unlimited segments).
# resend.com → Segments → create a segment for this project → copy the ID.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_SEGMENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# RESEND_FROM_EMAIL=GoAnyway <plans@goanyway.com>

# ── Stripe (Checkout Session — NOT Payment Links) ─────
# GoAnyway uses Checkout Sessions, not Payment Links.
# Reason: Payment Links don't carry metadata through the redirect.
# activity, city, comfort_level, and plan_id must survive to /confirm.
#
# TWO APPROACHES — pick one per project:
#
# PAYMENT LINKS (simpler — for tools that don't need post-payment data):
#   Create a Payment Link at stripe.com → Payment Links.
#   Set success_url to your tool page with ?paid=true appended.
#   Pass the link URL as the `checkoutUrl` prop on <PayGate>. No env vars needed.
#
# CHECKOUT SESSIONS (required when metadata must survive redirect):
#   Use when you need activity/city/plan data at /confirm, webhook triggers, etc.
#   Requires `npm install stripe` and the /api/checkout route.
#
# TEST MODE WORKFLOW:
#   1. Use test keys during development (stripe.com → Developers → API keys → Test mode)
#   2. Create a test product + price in test mode
#   3. Test the full checkout flow with card 4242 4242 4242 4242
#   4. Switch to live keys + live price ID at deploy time
#   5. IMPORTANT: disable Cash App Pay in Stripe Dashboard → Settings → Payment methods
#      (90%+ of disputed/cancelled transactions come from Cash App Pay)
#
STRIPE_SECRET_KEY=your_stripe_secret_key_here
# STRIPE_PUBLISHABLE_KEY only needed if doing client-side Stripe.js — not needed for Checkout Sessions
# STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_PRICE_ID=your_stripe_price_id_here
# Uncomment when webhook endpoint is live:
# STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ── AI providers ──────────────────────────────────────
# GPT-5 mini — structured JSON generation (~$0.003/call)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude Sonnet 4.6 — two roles:
#   (1) Event search via built-in web_search tool (~$0.01/search, domain-filtered to meetup/eventbrite/lu.ma)
#   (2) Emotional copy rewrite — comfort stat framing + script reassurance (~$0.015/call)
# Do NOT swap for Haiku — saves $0.01, produces noticeably flatter copy.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telnyx (SMS reminders + "Did you go?" follow-up) ──
# Schedules messages natively via Telnyx — no KV or cron needed.
# Setup: telnyx.com → Mission Control → Phone Numbers (buy toll-free, ~$2/mo)
#         → Messaging Profiles → create profile, set webhook URL, assign number
#         → Auth → API Keys → create key
#         → Messaging Profile → Public Keys (for webhook signature verification)
#
# Webhook URL to set in Telnyx portal:
#   https://goanyway.vercel.app/tools/goanyway/api/sms/webhook
#
# Routes:
#   POST /api/sms         — register opt-in, send confirmation, schedule reminder + follow-up
#   POST /api/sms/webhook — handle inbound replies (Y/N to "did you go?")
#
# Note: If TELNYX_API_KEY or TELNYX_FROM_NUMBER are missing, /api/sms returns
# success silently — SMS is optional and must never break the confirm page flow.
#
TELNYX_API_KEY=KEY0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELNYX_FROM_NUMBER=+18005551234
# Ed25519 public key from Mission Control → Messaging → Keys — used to verify webhook payloads.
# Leave unset in dev — verification is skipped gracefully when not configured.
# TELNYX_PUBLIC_KEY=base64-public-key-from-mission-control
